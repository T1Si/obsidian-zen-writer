{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "lib": ["DOM", "ES2018"],
    "moduleResolution": "Bundler",
    "allowJs": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "types": ["node"]
  },
  "include": ["main.ts"]
}
